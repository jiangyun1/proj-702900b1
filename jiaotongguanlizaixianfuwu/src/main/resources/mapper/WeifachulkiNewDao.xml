<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.WeifachulkiNewDao">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        a.id as id
        ,a.plate_number as plateNumber
        ,a.violation_type as violationType
        ,a.create_time as createTime
    </sql>
    <select id="selectListView" parameterType="map" resultType="com.entity.WeifachulkiNewEntity" >
        SELECT
        <include refid="Base_Column_List" />

        --         级联表的字段

        FROM weifachulkinew  a

        <where>
            <if test="params.ids != null">
                and a.id in
                <foreach item="item" index="index" collection="params.ids" open="(" separator="," close=")">
                #{item}
                </foreach>
            </if>
            <if test=" params.plateNumber != '' and params.plateNumber != null and params.plateNumber != 'null' ">
                and a.plate_number like CONCAT('%',#{params.plateNumber},'%')
            </if>
            <if test="params.violationType != null and params.violationType != ''">
                and a.violation_type = #{params.violationType}
            </if>
        </where>

        order by a.${params.orderBy} desc 
    </select>

</mapper>